  /* Satoshi Font Family */
  @font-face {
    font-family: 'Satoshi';
    src: url('{{ "fonts/Satoshi-Light.woff2" | asset_url }}') format('woff2'),
         url('{{ "fonts/Satoshi-Light.woff" | asset_url }}') format('woff'),
         url('{{ "fonts/Satoshi-Light.ttf" | asset_url }}') format('truetype');
    font-weight: 300;
    font-display: swap;
    font-style: normal;
  }

  @font-face {
